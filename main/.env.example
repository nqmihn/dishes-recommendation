APP_NAME=
APP_PORT=80
APP_DEBUG=true
APP_FALLBACK_LOCALE=vi

SWAGGER_ENABLED=true
SWAGGER_TITLE=''
SWAGGER_DESCRIPTION='<a href="/api/documentation-json" download="swagger.json">Download JSON</a>'
SWAGGER_PATH=api/documentation

DB_CONNECTION=pgsql
DB_TYPE=postgres
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=main
DB_USERNAME=postgres
DB_PASSWORD=123456
DB_LOGGING=true

REDIS_HOST=redis
REDIS_PORT=6379
CACHE_REDIS_DB=1

MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=123456

RABBITMQ_USER=admin
RABBITMQ_PASSWORD=123456
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/
RABBITMQ_QUEUE_NAME=user-queue
RABBITMQ_QUEUE_OPTION_DURABLE=true
RABBITMQ_AI_QUEUE_NAME=ai-product-queue